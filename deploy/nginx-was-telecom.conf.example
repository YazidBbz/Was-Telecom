server {
    listen 80;
    server_name was-telecom.fr www.was-telecom.fr;

    root /var/www/was-telecom/public;
    index index.html index.php;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location = /submit-form.php {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
    }

    location ~ \.php$ {
        return 404;
    }

    location ~ /\.(?!well-known) {
        deny all;
    }

    location ~* /(config|vendor|tmp|logs|deploy)/ {
        deny all;
    }

    location ~* /(database\.sql|setup-database\.bat|composer\.(json|lock)|package\.json)$ {
        deny all;
    }
}

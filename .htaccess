Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule ^(\.env|database\.sql|setup-database\.bat|package\.json|composer\.(json|lock))$ - [F,L]
  RewriteRule ^(config|vendor|tmp|logs)/ - [F,L]

  RewriteCond %{REQUEST_URI} !/public/
  RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
